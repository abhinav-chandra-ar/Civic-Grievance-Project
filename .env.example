# grievance-core — environment variable reference
#
# Module 1 (this module) reads only the minimum vars below to boot the project.
# Module 2 (configuration management) introduces typed config loading,
# Module 3 (environment management) introduces secrets and per-env overlays.
#
# Copy to .env for local development:
#   cp .env.example .env

# --- Django core -------------------------------------------------------------
DJANGO_SETTINGS_MODULE=grievance_core.settings.dev
DJANGO_SECRET_KEY=change-me-in-production-this-is-a-skeleton-placeholder
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- Database (PostgreSQL + PostGIS) -----------------------------------------
DATABASE_URL=postgis://grievance:grievance@localhost:5432/grievance_core

# --- Cache / Celery broker ---------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- CORS --------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# --- Time / language ---------------------------------------------------------
TIME_ZONE=Asia/Kolkata
LANGUAGE_CODE=en
